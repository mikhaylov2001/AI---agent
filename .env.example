# Telegram (@BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=NikiMindBot

# OpenAI (для диалога и писем)
OPENAI_API_KEY=sk-proj-...

# Neon PostgreSQL (формат JDBC для Spring)
# Из строки postgresql://user:pass@host/db?sslmode=require
DB_URL=jdbc:postgresql://YOUR_HOST/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=your_password

# HH.ru OAuth (dev.hh.ru, redirect = URL сервиса на Render)
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_REDIRECT_URI=https://your-app.onrender.com/hh/callback

# Локально
PORT=8080
