# === ОБЯЗАТЕЛЬНО ===

# Telegram — токен от @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=NikiMindBot

# OpenAI — ключ с https://platform.openai.com/api-keys
# Это НЕ подписка ChatGPT Plus — нужен отдельный API key и баланс на аккаунте.
OPENAI_API_KEY=sk-proj-...

# Neon PostgreSQL → JDBC для Spring
# Из postgresql://USER:PASS@HOST/neondb?sslmode=require
DB_URL=jdbc:postgresql://YOUR_HOST/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=your_password

# === ЛОКАЛЬНО (без публичного URL) ===
TELEGRAM_DELIVERY_MODE=polling

# === RENDER (webhook) — задай на сайте Render, не в .env ===
# TELEGRAM_DELIVERY_MODE=webhook
# TELEGRAM_WEBHOOK_URL=https://your-app.onrender.com
# (или Render сам подставит RENDER_EXTERNAL_URL)

# === OpenAI (опционально) ===
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=600
# Прокси / OpenRouter (если прямой api.openai.com недоступен):
# OPENAI_API_BASE_URL=https://openrouter.ai/api/v1

# === HH.ru (опционально, для откликов) ===
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_REDIRECT_URI=https://your-app.onrender.com/hh/callback

PORT=8080
