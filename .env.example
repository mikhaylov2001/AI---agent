# === ОБЯЗАТЕЛЬНО ===

TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=NikiMindBot

# Groq — бесплатный tier: console.groq.com → API Keys
GROQ_API_KEY=gsk_...

DB_URL=jdbc:postgresql://YOUR_HOST/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=your_password

TELEGRAM_DELIVERY_MODE=polling

# === LLM (Groq по умолчанию) ===
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
# LLM_MODEL=llama-3.1-8b-instant   # быстрее, проще

# === Perplexity / OpenAI (опционально) ===
# LLM_PROVIDER=perplexity
# LLM_API_BASE_URL=https://api.perplexity.ai
# LLM_MODEL=sonar
# PERPLEXITY_API_KEY=pplx-...

HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_REDIRECT_URI=https://your-app.onrender.com/hh/callback

PORT=8080
