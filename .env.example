# === ОБЯЗАТЕЛЬНО ===

TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=NikiMindBot

GROQ_API_KEY=gsk_...

DB_URL=jdbc:postgresql://YOUR_HOST/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=your_password

TELEGRAM_DELIVERY_MODE=polling

# === LLM (Groq по умолчанию) ===
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# === Webhook (Render) ===
# TELEGRAM_DELIVERY_MODE=webhook
# TELEGRAM_WEBHOOK_URL=https://ai-agent-fgo1.onrender.com
# TELEGRAM_WEBHOOK_SECRET=random-secret-string

# === HH.ru ===
# HH_CLIENT_ID=
# HH_CLIENT_SECRET=
# HH_REDIRECT_URI=https://ai-agent-fgo1.onrender.com/hh/callback
# HH_USER_AGENT=NikiBot/2.0 (твой@email.com)
# HH_DEFAULT_AREA=1
# HH_SEARCH_PER_PAGE=8

# === Render Free: внешний cron ===
# NIKI_CRON_SECRET=random-cron-secret
# UptimeRobot POST https://your-app.onrender.com/internal/cron
# Header: X-Cron-Secret: random-cron-secret (каждый час)

PORT=8080
