# === ОБЯЗАТЕЛЬНО ===

# Telegram — токен от @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=NikiMindBot

# Perplexity — ключ с https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# Neon PostgreSQL → JDBC для Spring
DB_URL=jdbc:postgresql://YOUR_HOST/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=your_password

# === ЛОКАЛЬНО ===
TELEGRAM_DELIVERY_MODE=polling

# === LLM (Perplexity по умолчанию) ===
LLM_PROVIDER=perplexity
LLM_MODEL=sonar
# LLM_MODEL=sonar-pro   # умнее, дороже
# LLM_MAX_TOKENS=900

# === Вернуть OpenAI (если нужно) ===
# LLM_PROVIDER=openai
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-proj-...

# === HH.ru (опционально) ===
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_REDIRECT_URI=https://your-app.onrender.com/hh/callback

PORT=8080
